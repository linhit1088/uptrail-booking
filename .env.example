# ===== DATABASE =====
# Local development: SQLite
# DATABASE_URL="file:./dev.db"
# Production: PostgreSQL (Neon)
# DATABASE_URL="postgresql://user:password@ep-xxx.region.neon.tech/uptrail?sslmode=require"
DATABASE_URL="file:./dev.db"

# ===== AUTH (NextAuth.js) =====
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Set to your production domain
NEXTAUTH_URL="http://localhost:3000"

# ===== EMAIL (Resend) =====
# Get from https://resend.com/api-keys
RESEND_API_KEY=""
# Sender address (must verify domain at Resend)
EMAIL_FROM="Uptrail <noreply@uptrail.vn>"

# ===== ANALYTICS =====
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=""

# ===== APP =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Uptrail"
